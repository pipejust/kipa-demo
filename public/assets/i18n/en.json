  "legal": {
    "contact": "Contact",
    "privacy": {
      "title": "Privacy policy",
      "lead": "At K!dS Andorra we protect the personal data of students, families and staff in line with the General Data Protection Regulation (GDPR).",
      "s1Title": "What data we collect",
      "s1Body": "We only collect the data needed to manage admissions, enrolment, attendance, communications and payments: identification, contact, medical (allergies, medication, emergency contact) and administrative information.",
      "s2Title": "How we use data",
      "s2Body": "Data is used exclusively for educational and administrative purposes. It is not sold or shared with unauthorised third parties. Some data may be shared with public administrations when required by law.",
      "s3Title": "Your rights",
      "s3Body": "You have the right to access, rectify, delete, object to and port your data at any time. You can also withdraw consent for non-mandatory uses (e.g. photographs in internal activities).",
      "s4Title": "Retention and security",
      "s4Body": "Data is retained for the period required to meet legal and academic obligations. Our systems are protected with in-transit encryption, access controls and event auditing."
    },
    "terms": {
      "title": "Terms of use",
      "lead": "Use of the K!dS platform is subject to these terms. By accessing it you accept all of the following points.",
      "s1Title": "Access and accounts",
      "s1Body": "The platform is accessed with a personal, non-transferable account. Each user is responsible for the confidentiality of their credentials and for any activity generated from their account.",
      "s2Title": "Acceptable use",
      "s2Body": "The platform is used for educational and administrative purposes. Uploading illicit, offensive or rights-infringing content is not permitted. The school reserves the right to suspend accounts that breach these rules.",
      "s3Title": "Liability",
      "s3Body": "K!dS Andorra makes reasonable efforts to ensure availability and security, but is not liable for interruptions due to external causes (maintenance, force majeure, third-party provider incidents).",
      "s4Title": "Modifications",
      "s4Body": "These terms may be updated when necessary. We'll notify you of significant changes by email or within the platform."
    }
  },
