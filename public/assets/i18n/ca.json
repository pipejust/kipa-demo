  "legal": {
    "contact": "Contacte",
    "privacy": {
      "title": "Política de privacitat",
      "lead": "A K!dS Andorra protegim les dades personals d'alumnes, famílies i personal del centre seguint el Reglament General de Protecció de Dades (RGPD).",
      "s1Title": "Quines dades recollim",
      "s1Body": "Recollim només les dades necessàries per gestionar el procés d'admissions, la matrícula, l'assistència, les comunicacions i els pagaments del centre: dades identificatives, de contacte, mèdiques (al·lèrgies, medicació, contacte d'emergència) i administratives.",
      "s2Title": "Com utilitzem les dades",
      "s2Body": "Les dades s'utilitzen exclusivament per a les finalitats educatives i administratives del centre. No es venen ni es comparteixen amb tercers no autoritzats. Algunes dades poden ser compartides amb administracions públiques quan així ho exigeix la llei.",
      "s3Title": "Els teus drets",
      "s3Body": "Tens dret a accedir, rectificar, suprimir, oposar-te i portar les teves dades en qualsevol moment. També pots retirar el consentiment per a usos no obligatoris (per exemple, fotografies en activitats internes).",
      "s4Title": "Conservació i seguretat",
      "s4Body": "Les dades es conserven durant el període necessari per complir amb les obligacions legals i acadèmiques. Els nostres sistemes es protegeixen amb xifratge en trànsit, controls d'accés i auditoria d'esdeveniments."
    },
    "terms": {
      "title": "Condicions d'ús",
      "lead": "L'ús de la plataforma K!dS està subjecte a aquestes condicions. En accedir-hi acceptes tots els punts següents.",
      "s1Title": "Accés i comptes",
      "s1Body": "L'accés a la plataforma es realitza amb un compte personal i intransferible. Cada usuari és responsable de la confidencialitat de les seves credencials i de tota l'activitat que es generi des del seu compte.",
      "s2Title": "Ús acceptable",
      "s2Body": "La plataforma s'utilitza per a finalitats educatives i administratives. No es permet pujar continguts il·lícits, ofensius o que infringeixin drets de tercers. El centre es reserva el dret a suspendre comptes que incompleixin aquestes normes.",
      "s3Title": "Responsabilitat",
      "s3Body": "K!dS Andorra fa esforços raonables per garantir la disponibilitat i seguretat del servei, però no es responsabilitza d'interrupcions per causes alienes (manteniment, força major, incidents de tercers proveïdors).",
      "s4Title": "Modificacions",
      "s4Body": "Aquestes condicions poden actualitzar-se quan sigui necessari. Et notificarem els canvis significatius per correu o dins de la pròpia plataforma."
    }
  },
