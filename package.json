{
  "name": "frontend",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "lint": "ng lint",
    "test:ci": "ng test --watch=false --browsers=ChromeHeadlessCI --code-coverage",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "axe": "node ./e2e/axe-runner.js",
    "compodoc": "compodoc -p tsconfig.json -d compodoc",
    "openapi:types": "openapi-typescript http://localhost/openapi.json -o src/app/core/api/types.gen.ts"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^18.2.0",
    "@angular/common": "^18.2.0",
    "@angular/compiler": "^18.2.0",
    "@angular/core": "^18.2.0",
    "@angular/forms": "^18.2.0",
    "@angular/platform-browser": "^18.2.0",
    "@angular/platform-browser-dynamic": "^18.2.0",
    "@angular/router": "^18.2.0",
    "@jsverse/transloco": "^7.5.0",
    "@ngrx/signals": "^18.0.0",
    "@tanstack/angular-query-experimental": "^5.59.0",
    "date-fns": "^3.6.0",
    "lucide-angular": "^0.453.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "zod": "^3.23.8",
    "zone.js": "~0.14.10"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^18.2.21",
    "@angular-eslint/builder": "^18.4.3",
    "@angular-eslint/eslint-plugin": "^18.4.3",
    "@angular-eslint/eslint-plugin-template": "^18.4.3",
    "@angular-eslint/template-parser": "^18.4.3",
    "@angular/cli": "^18.2.21",
    "@angular/compiler-cli": "^18.2.0",
    "@compodoc/compodoc": "^1.1.25",
    "@playwright/test": "^1.48.0",
    "@types/jasmine": "~5.1.0",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "axe-playwright": "^2.0.1",
    "eslint": "^8.57.1",
    "jasmine-core": "~5.2.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "openapi-typescript": "^7.4.1",
    "prettier": "^3.3.3",
    "typescript": "~5.5.2"
  },
  "optionalDependencies": {
    "@rollup/rollup-linux-arm64-gnu": "^4.60.2"
  }
}
